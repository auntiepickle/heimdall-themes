#!/usr/bin/with-contenv bash
# Runs on every container start AFTER linuxserver populates /app/www.
# Copies staged theme files into the live app tree + runs migrations.
set -e

STAGE=/heimdall-themes
APP=/app/www

echo "[heimdall-themes] waiting for app install..."
for i in $(seq 1 60); do
    [ -f "$APP/artisan" ] && break
    sleep 1
done

if [ ! -f "$APP/artisan" ]; then
    echo "[heimdall-themes] ERROR: $APP/artisan not found after 60s — theme engine will not work"
    exit 1
fi

echo "[heimdall-themes] overlaying theme files into $APP"
cp -af "$STAGE"/* "$APP"/
chown -R abc:users \
    "$APP/app/Http/Controllers/ThemeController.php" \
    "$APP/app/Models/Theme.php" \
    "$APP/resources/views/settings/themes.blade.php" \
    "$APP/resources/views/layouts/app.blade.php" \
    "$APP/resources/themes" \
    "$APP/public/themes" \
    "$APP/routes/web.php" \
    "$APP/config/heimdall-themes.php"

# Laravel storage:link — AppServiceProvider calls Artisan::call('storage:link')
# on boot if public/storage/.gitignore is missing, which fails with permission
# denied inside the container. Create the symlink here so the app skips that call.
if [ ! -L "$APP/public/storage" ]; then
    ln -sf "$APP/storage/app/public" "$APP/public/storage"
    chown -h abc:users "$APP/public/storage"
    echo "[heimdall-themes] created storage symlink"
fi

# One-time migration: clear legacy custom.js/custom.css that predates the theme
# engine. Only runs once — marker file prevents re-clearing on future restarts,
# so any new customizations the user adds after migration are preserved.
MIGRATED_MARKER="/config/.heimdall-themes-migrated"
if [ ! -f "$MIGRATED_MARKER" ]; then
    echo "[heimdall-themes] first run — migrating legacy custom JS/CSS"
    for f in /config/www/custom.js /config/www/custom.css; do
        if [ -s "$f" ]; then
            echo "[heimdall-themes] clearing legacy $f"
            : > "$f"
        fi
    done
    s6-setuidgid abc php << 'EOPHP'
<?php
$dbPath = '/config/www/app.sqlite';
if (!file_exists($dbPath)) { echo "[heimdall-themes] no DB found, skip\n"; exit(0); }
$db = new PDO("sqlite:$dbPath");
$db->exec("UPDATE settings SET value='' WHERE key IN ('custom_js','custom_css') AND value!=''");
$r = $db->exec("UPDATE setting_user SET uservalue='' WHERE setting_id IN (SELECT id FROM settings WHERE key IN ('custom_js','custom_css')) AND uservalue!=''");
echo "[heimdall-themes] cleared custom_js/custom_css from DB ($r user rows)\n";
EOPHP
    touch "$MIGRATED_MARKER"
    echo "[heimdall-themes] migration complete, marker written"
else
    echo "[heimdall-themes] already migrated, skipping legacy clear"
fi

# Pass THEME_IMAGE_URL to Laravel's .env so PHP-FPM can read it
if [ -n "${THEME_IMAGE_URL:-}" ] && [ -f "$APP/.env" ]; then
    if grep -q "^THEME_IMAGE_URL=" "$APP/.env" 2>/dev/null; then
        sed -i "s|^THEME_IMAGE_URL=.*|THEME_IMAGE_URL=${THEME_IMAGE_URL}|" "$APP/.env"
    else
        echo "THEME_IMAGE_URL=${THEME_IMAGE_URL}" >> "$APP/.env"
    fi
    echo "[heimdall-themes] THEME_IMAGE_URL written to .env"
fi

cd "$APP"
s6-setuidgid abc php artisan config:clear 2>&1 || true
s6-setuidgid abc php artisan route:clear  2>&1 || true
s6-setuidgid abc php artisan view:clear   2>&1 || true

echo "[heimdall-themes] init complete"
